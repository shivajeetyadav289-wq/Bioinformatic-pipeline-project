# phylogenetic analysis
from Bio import AlignIO
from Bio.Phylo.TreeConstruction import DistanceCalculator
from Bio.Phylo.TreeConstruction import DistanceTreeConstructor
from Bio import Phylo

# Read alignment
alignment = AlignIO.read("aligned.fasta", "fasta")

print("Number of sequences:", len(alignment))
print("Alignment length:", alignment.get_alignment_length())

# Calculate evolutionary distances
calculator = DistanceCalculator("identity")
distance_matrix = calculator.get_distance(alignment)

print("\nDistance Matrix")
print(distance_matrix)

# Build Neighbor Joining Tree
constructor = DistanceTreeConstructor()
tree = constructor.nj(distance_matrix)

# Save tree
Phylo.write(tree, "rv1515c_tree.nwk", "newick")

print("\nPhylogenetic tree saved as rv1515c_tree.nwk")

# Display tree in text format
print("\nPhylogenetic Tree")
Phylo.draw_ascii(tree)
