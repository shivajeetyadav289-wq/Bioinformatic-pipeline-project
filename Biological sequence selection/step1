## Step 1: Sequence retrieval:
from Bio import SeqIO

with open("rv1515c.fasta","r") as f:
    record = SeqIO.read(f,"fasta")
    
print("The following protien record has Nucleotide ID: ", record.id)
print(record.description)
print("The length of the sequence is:", len(record.seq), "amino acid")
print("The protien sequence is: ", record.seq)
